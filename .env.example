# Copia a `.env` y rellena los valores. No commitees `.env`.

# --- Base de datos PostgreSQL (requerido; ver payload.config.ts) ---
DATABASE_URI=postgresql://usuario:contraseña@127.0.0.1:5432/nombre_db

# --- Payload / Next ---
PAYLOAD_SECRET=genera_una_cadena_larga_aleatoria
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

CRON_SECRET=secreto_para_jobs_cron
PREVIEW_SECRET=secreto_para_preview

# --- Google Cloud Storage (plugin en src/plugins/index.ts) ---
# Necesario para subidas de medios. Define las claves aunque estén vacías si no usas GCS aún.
# GCS_PRIVATE_KEY: PEM del service account; en una línea puedes usar \n escapados.
GCS_BUCKET=
GCS_ENDPOINT=
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
